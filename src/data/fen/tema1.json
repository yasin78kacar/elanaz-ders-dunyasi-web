            "gorsel": {
              "tur": "fen",
              "mod": "anlatim",
              "sahne": "cc-anlatim-1"
            }
          },
          {
            "metin": "Canlıların 7 yaşam özelliği vardır: Büyür, beslenir, solur, ürer, hareket eder, tepki verir ve ölür.",
